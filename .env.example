# ===========================================
# Sola Devotion - Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI-generated devotionals)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ESV API Key (optional - for ESV translation support)
# Get yours free at: https://api.esv.org/
ESV_API_KEY=

# API.Bible Key (optional - unlocks NASB, NIV, NKJV, CSB translations)
# Get yours free at: https://scripture.api.bible/
API_BIBLE_KEY=

# Server port
PORT=3000

# VAPID keys for push notifications (auto-generated by: npm run generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# Daily devotion notification time (24h format, HH:MM)
NOTIFICATION_TIME=06:00

# Default Bible translation
DEFAULT_TRANSLATION=kjv
