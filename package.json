{
  "name": "sola-devotion",
  "version": "1.0.0",
  "description": "Reformed daily devotional app with AI-generated devotionals and prayer tracking",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npx vite --host",
    "build": "cd client && npx vite build",
    "start": "NODE_ENV=production node server/index.js",
    "generate-vapid-keys": "node generate-vapid-keys.js",
    "setup": "npm install && cd client && npm install && cd .. && node generate-vapid-keys.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
